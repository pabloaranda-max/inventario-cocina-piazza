      </div>
    </div>
  </div>

  <!-- PRODUCTOS -->
  <div class="section" id="tab-productos">
    <div class="pedidos-header">
      <div>
        <div class="section-title">Catálogo</div>
        <div class="section-sub">Productos disponibles para venta</div>
      </div>
      <button class="btn btn-primary" onclick="openModal('modal-producto')">+ Nuevo producto</button>
    </div>
    <div class="cards-grid" id="productos-grid">
      <div class="empty-state" style="grid-column:1/-1">
        <span class="emoji">🧀</span>Agrega tu primer producto
