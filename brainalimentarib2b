      </div>
      <div class="stat-card">
        <div class="stat-num" id="stat-clientes">—</div>
        <div class="stat-label">Clientes activos</div>
      </div>
    </div>

    <div class="pedidos-header">
      <div>
        <div class="section-title">Pedidos</div>
