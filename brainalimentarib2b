<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Alimentari – Pedidos B2B</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #F5F0E8;
    --dark: #1A1612;
    --terracotta: #C4613A;
    --olive: #6B7A3E;
    --gold: #D4A853;
    --light-border: #E0D8CC;
    --muted: #8A7F72;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Mono', monospace;
    background: var(--cream);
    color: var(--dark);
    min-height: 100vh;
  }

  /* LOADING OVERLAY */
  #loading-overlay {
    position: fixed;
    inset: 0;
    background: var(--dark);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    transition: opacity 0.4s;
  }
  #loading-overlay.hidden { opacity: 0; pointer-events: none; }
  .loading-logo {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    color: var(--cream);
    margin-bottom: 20px;
  }
  .loading-logo span { color: var(--terracotta); font-style: italic; }
  .spinner {
    width: 32px; height: 32px;
    border: 2px solid rgba(245,240,232,0.2);
    border-top-color: var(--terracotta);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  .loading-text {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 14px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* TOAST */
  #toast {
    position: fixed;
    bottom: 24px;
    right: 24px;
    background: var(--dark);
    color: var(--cream);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    padding: 12px 20px;
    z-index: 9000;
    opacity: 0;
    transform: translateY(8px);
    transition: all 0.2s;
    pointer-events: none;
    max-width: 280px;
  }
  #toast.show { opacity: 1; transform: translateY(0); }
  #toast.error { background: var(--terracotta); }

  /* HEADER */
  header {
    background: var(--dark);
    color: var(--cream);
    padding: 20px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    letter-spacing: 0.05em;
  }
  .logo span { color: var(--terracotta); font-style: italic; }

  .nav-tabs { display: flex; gap: 4px; }

  .tab-btn {
    background: none;
    border: 1px solid rgba(245,240,232,0.2);
    color: var(--cream);
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 8px 16px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .tab-btn.active, .tab-btn:hover {
    background: var(--terracotta);
    border-color: var(--terracotta);
  }

  /* MAIN LAYOUT */
  .container { max-width: 1100px; margin: 0 auto; padding: 40px 24px; }
  .section { display: none; }
  .section.active { display: block; }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: 8px;
  }

  .section-sub {
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 32px;
  }

  /* CARDS GRID */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
    margin-bottom: 32px;
  }

  .card {
    background: white;
    border: 1px solid var(--light-border);
    padding: 24px;
    position: relative;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .card:hover { transform: translateY(-2px); box-shadow: 4px 4px 0px var(--terracotta); }

  .card-label { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin-bottom: 8px; }
  .card-name { font-family: 'Playfair Display', serif; font-size: 1.2rem; margin-bottom: 4px; }
  .card-detail { font-size: 0.75rem; color: var(--muted); margin-bottom: 3px; }
  .card-actions { display: flex; gap: 8px; margin-top: 16px; }

  .btn {
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 8px 14px;
    border: 1px solid var(--dark);
    background: none;
    cursor: pointer;
    transition: all 0.15s;
  }
  .btn:hover { background: var(--dark); color: var(--cream); }
  .btn-primary { background: var(--terracotta); color: white; border-color: var(--terracotta); }
  .btn-primary:hover { background: #a84e2e; border-color: #a84e2e; color: white; }
  .btn-sm { padding: 5px 10px; font-size: 0.62rem; }
  .btn:disabled { opacity: 0.5; cursor: not-allowed; }

  .tag {
    display: inline-block;
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 2px;
    font-weight: 500;
  }
  .tag-pasta    { background: #EDE8DC; color: #6B5B3E; }
  .tag-embutido { background: #F5E6E0; color: #8B3A2A; }
  .tag-lacteo   { background: #E8EFE0; color: #4A6028; }
  .tag-otro     { background: #E8E8E8; color: #555; }

  /* FORM */
  .form-section { background: white; border: 1px solid var(--light-border); padding: 32px; max-width: 700px; }

  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-group.full { grid-column: 1 / -1; }

  label { font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); }

  input, select, textarea {
    font-family: 'DM Mono', monospace;
    font-size: 0.82rem;
    border: 1px solid var(--light-border);
    padding: 10px 12px;
    background: var(--cream);
    color: var(--dark);
    outline: none;
    transition: border-color 0.15s;
  }
  input:focus, select:focus, textarea:focus { border-color: var(--terracotta); }
  textarea { resize: vertical; min-height: 80px; }

  .form-actions { margin-top: 24px; display: flex; gap: 12px; }

  /* PEDIDOS TABLE */
  .pedidos-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
  .filters { display: flex; gap: 8px; }

  .filter-btn {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 12px;
    border: 1px solid var(--light-border);
    background: none;
    cursor: pointer;
    transition: all 0.15s;
  }
  .filter-btn.active { background: var(--dark); color: var(--cream); border-color: var(--dark); }

  .table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: 0.78rem; }
  thead tr { border-bottom: 2px solid var(--dark); }
  th {
    text-align: left;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 10px 14px;
    font-weight: 400;
  }
  td { padding: 14px; border-bottom: 1px solid var(--light-border); vertical-align: middle; }
  tr:hover td { background: rgba(245,240,232,0.6); }

  .status-badge {
    display: inline-block;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 9px;
    border-radius: 2px;
    font-weight: 500;
  }
  .status-recibido   { background: #EDE8DC; color: #6B5B3E; }
  .status-preparando { background: #FFF3CD; color: #856404; }
  .status-entregado  { background: #D1E7DD; color: #155724; }
  .status-pendiente  { background: #F8D7DA; color: #842029; }
  .status-pagado     { background: #D1E7DD; color: #155724; }
  .status-facturado  { background: #D1E7DD; color: #155724; }
  .status-sin-factura { background: #FFF3CD; color: #856404; }

  /* STATS */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }
  .stat-card { background: var(--dark); color: var(--cream); padding: 20px 24px; }
  .stat-num { font-family: 'Playfair Display', serif; font-size: 2.2rem; color: var(--gold); }
  .stat-label { font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); margin-top: 4px; }

  /* MODAL */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(26,22,18,0.7);
    z-index: 200;
    align-items: center;
    justify-content: center;
  }
  .modal-overlay.open { display: flex; }
  .modal {
    background: var(--cream);
    border: 1px solid var(--light-border);
    padding: 32px;
    width: 90%;
    max-width: 540px;
    max-height: 85vh;
    overflow-y: auto;
  }
  .modal-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    margin-bottom: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .close-btn { background: none; border: none; font-size: 1.4rem; cursor: pointer; color: var(--muted); }

  /* PRODUCTO ROW EN PEDIDO */
  .producto-row {
    display: grid;
    grid-template-columns: 1fr auto auto auto;
    gap: 10px;
    align-items: center;
    margin-bottom: 8px;
  }
  .remove-btn { background: none; border: none; color: var(--terracotta); cursor: pointer; font-size: 1rem; }

  .divider { border: none; border-top: 1px solid var(--light-border); margin: 24px 0; }

  .empty-state { text-align: center; padding: 48px; color: var(--muted); font-size: 0.8rem; letter-spacing: 0.05em; }
  .empty-state .emoji { font-size: 2rem; margin-bottom: 12px; display: block; }

  @media (max-width: 600px) {
    .stats-row { grid-template-columns: 1fr 1fr; }
    .form-grid { grid-template-columns: 1fr; }
    header { padding: 16px; }
    .logo { font-size: 1.2rem; }
    .nav-tabs { gap: 2px; }
    .tab-btn { padding: 6px 10px; font-size: 0.62rem; }
  }
</style>
</head>
<body>

<!-- LOADING OVERLAY -->
<div id="loading-overlay">
  <div class="loading-logo">Aliment<span>ari</span></div>
  <div class="spinner"></div>
  <div class="loading-text">Cargando datos...</div>
</div>

<!-- TOAST -->
<div id="toast"></div>

<header>
