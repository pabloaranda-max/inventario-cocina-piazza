<script>
// ================================================================
//  CONFIGURACIÓN — REEMPLAZA ESTA URL DESPUÉS DE PUBLICAR EL SCRIPT
// ================================================================
const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwWR5ZtNZUz2sdYs2NCscEmmGIRJAZgOJ2ZaDhuLZko_APu7OHBs-LuRGVmJTu-LKys/exec';

// ================================================================
//  ESTADO EN MEMORIA
// ================================================================
let clientes  = [];
let productos = [];
let pedidos   = [];

// ================================================================
//  API — COMUNICACIÓN CON APPS SCRIPT
// ================================================================
async function api(action, body = {}) {
  const payload = { action, ...body };
  const res = await fetch(SCRIPT_URL, {
    method: 'POST',
    body: JSON.stringify(payload),
    headers: { 'Content-Type': 'text/plain' }  // evita CORS preflight
  });
  if (!res.ok) throw new Error('Error de red: ' + res.status);
  const json = await res.json();
  if (json.error) throw new Error(json.error);
  return json;
}

// Carga inicial — trae los tres catálogos de una vez
async function cargarTodo() {
  const data = await api('getAll');
  clientes  = data.clientes  || [];
  productos = data.productos || [];
  pedidos   = data.pedidos   || [];
  // Normalizar tipos
  clientes.forEach(c => { c.id = Number(c.id); });
  productos.forEach(p => { p.id = Number(p.id); p.precio = Number(p.precio); p.disponible = Number(p.disponible); });
  pedidos.forEach(p => {
    p.id = Number(p.id);
    p.clienteId = Number(p.clienteId);
    if (!Array.isArray(p.items)) p.items = [];
    p.items.forEach(i => { i.productoId = Number(i.productoId); i.qty = Number(i.qty); });
    if (!p.factura) p.factura = 'Sin factura';
  });
}

// ================================================================
//  TOAST
// ================================================================
let toastTimer;
function toast(msg, tipo = 'ok') {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'show' + (tipo === 'error' ? ' error' : '');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => { el.className = ''; }, 3000);
}

// ================================================================
//  UTILS
// ================================================================
function getCliente(id)  { return clientes.find(c => c.id === id); }
function getProducto(id) { return productos.find(p => p.id === id); }

function calcTotal(items) {
  return items.reduce((sum, item) => {
    const p = getProducto(item.productoId);
    return sum + (p ? p.precio * item.qty : 0);
  }, 0);
}

function formatMXN(n) {
  return '$' + Number(n).toLocaleString('es-MX', { minimumFractionDigits: 0 });
}

// ================================================================
//  TABS
// ================================================================
function showTab(tab, btn) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + tab).classList.add('active');
  if (btn) btn.classList.add('active');
  renderAll();
}

// ================================================================
//  MODALES
// ================================================================
function openModal(id) {
  document.getElementById(id).classList.add('open');
  if (id === 'modal-pedido') {
    renderClientesSelect();
    renderProductosPedidoList([]);
    document.getElementById('ped-fecha').value = '';
    document.getElementById('ped-notas').value = '';
  }
}

function closeModal(id) {
  document.getElementById(id).classList.remove('open');
}

document.querySelectorAll('.modal-overlay').forEach(m => {
  m.addEventListener('click', e => { if (e.target === m) m.classList.remove('open'); });
});

// ================================================================
//  RENDER — PEDIDOS
// ================================================================
let filtroActivo = 'todos';

function filtrarPedidos(filtro, btn) {
  filtroActivo = filtro;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderPedidos();
}

function renderPedidos() {
  const tbody = document.getElementById('pedidos-tbody');
  const empty = document.getElementById('pedidos-empty');
  const lista = filtroActivo === 'todos' ? pedidos : pedidos.filter(p => p.estado === filtroActivo);

  if (lista.length === 0) {
    tbody.innerHTML = '';
    empty.style.display = 'block';
    return;
  }

  empty.style.display = 'none';
  tbody.innerHTML = lista.map(p => {
    const cli   = getCliente(p.clienteId);
    const total = calcTotal(p.items);
    const itemsStr = p.items.map(i => {
      const pr = getProducto(i.productoId);
      return pr ? `${pr.nombre} ×${i.qty}` : '';
    }).filter(Boolean).join(', ');

    const estadoClass   = { 'Recibido': 'status-recibido', 'Preparando': 'status-preparando', 'Entregado': 'status-entregado' }[p.estado] || 'status-recibido';
    const pagoClass     = p.pago === 'Pagado' ? 'status-pagado' : 'status-pendiente';
    const facturaClass  = p.factura === 'Facturada' ? 'status-facturado' : 'status-sin-factura';
    const selectStyle   = "border:none;cursor:pointer;font-family:'DM Mono',monospace;font-size:0.6rem;letter-spacing:0.08em;text-transform:uppercase;appearance:none;padding:3px 9px;border-radius:2px";

    return `<tr>
      <td style="color:var(--muted)">#${String(p.id).slice(-4)}</td>
      <td><strong>${cli ? cli.nombre : '—'}</strong></td>
      <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:0.72rem;color:var(--muted)">${itemsStr}</td>
      <td><strong>${formatMXN(total)}</strong></td>
      <td style="font-size:0.75rem">${p.fecha || '—'}</td>
      <td>
        <select class="status-badge ${estadoClass}" onchange="cambiarEstadoPedido(${p.id},'estado',this.value,this)" style="${selectStyle}">
          <option ${p.estado==='Recibido'?'selected':''}>Recibido</option>
          <option ${p.estado==='Preparando'?'selected':''}>Preparando</option>
          <option ${p.estado==='Entregado'?'selected':''}>Entregado</option>
        </select>
      </td>
      <td>
        <select class="status-badge ${pagoClass}" onchange="cambiarEstadoPedido(${p.id},'pago',this.value,this)" style="${selectStyle}">
          <option ${p.pago==='Pendiente'?'selected':''}>Pendiente</option>
          <option ${p.pago==='Pagado'?'selected':''}>Pagado</option>
        </select>
      </td>
      <td>
        <select class="status-badge ${facturaClass}" onchange="cambiarEstadoPedido(${p.id},'factura',this.value,this)" style="${selectStyle}">
          <option ${p.factura==='Sin factura'?'selected':''}>Sin factura</option>
          <option ${p.factura==='Facturada'?'selected':''}>Facturada</option>
        </select>
      </td>
      <td><button class="btn btn-sm" onclick="eliminarPedido(${p.id})" style="border-color:var(--terracotta);color:var(--terracotta)">✕</button></td>
    </tr>`;
  }).join('');
}

async function cambiarEstadoPedido(id, campo, valor, select) {
  const p = pedidos.find(x => x.id === id);
  if (!p) return;
  const anterior = p[campo];
  p[campo] = valor;
  renderPedidos();
  renderStats();
  try {
    await api('updatePedido', { id, cambios: { [campo]: valor } });
    toast('Pedido actualizado');
  } catch (e) {
    p[campo] = anterior; // revertir
    renderPedidos();
    toast('Error al actualizar', 'error');
  }
}

async function eliminarPedido(id) {
  if (!confirm('¿Eliminar este pedido?')) return;
  const prev = [...pedidos];
  pedidos = pedidos.filter(p => p.id !== id);
  renderAll();
  try {
    await api('deletePedido', { id });
    toast('Pedido eliminado');
  } catch (e) {
    pedidos = prev;
    renderAll();
    toast('Error al eliminar', 'error');
  }
}

// ================================================================
//  RENDER — STATS
// ================================================================
function renderStats() {
  const hoy = new Date();
  const esteMe = pedidos.filter(p => {
    const d = new Date(p.fecha);
    return d.getMonth() === hoy.getMonth() && d.getFullYear() === hoy.getFullYear();
  });
  const porEntregar = pedidos.filter(p => p.estado !== 'Entregado').length;
  const porCobrar   = pedidos.filter(p => p.pago !== 'Pagado').reduce((s,p) => s + calcTotal(p.items), 0);
  const clientesActivos = [...new Set(pedidos.map(p => p.clienteId))].length;

  document.getElementById('stat-total').textContent     = esteMe.length;
  document.getElementById('stat-pendientes').textContent = porEntregar;
  document.getElementById('stat-cobrar').textContent    = formatMXN(porCobrar);
  document.getElementById('stat-clientes').textContent  = clientesActivos;
}

// ================================================================
//  RENDER — CLIENTES
// ================================================================
function renderClientes() {
  const grid = document.getElementById('clientes-grid');
  if (clientes.length === 0) {
    grid.innerHTML = '<div class="empty-state" style="grid-column:1/-1"><span class="emoji">🍽️</span>Agrega tu primer cliente B2B</div>';
    return;
  }
  grid.innerHTML = clientes.map(c => `
    <div class="card">
      <div class="card-label">Restaurante B2B</div>
      <div class="card-name">${c.nombre}</div>
      <div class="card-detail">👤 ${c.contacto}</div>
      <div class="card-detail">📱 ${c.tel}</div>
      <div class="card-detail">📧 ${c.email}</div>
      <div class="card-detail">🧾 RFC: ${c.rfc}</div>
      <div class="card-detail">📍 ${c.dir}</div>
      <div class="card-detail">📅 ${c.dias}</div>
      <div class="card-actions">
        <button class="btn btn-sm btn-primary" onclick="nuevoPedidoCliente(${c.id})">Nuevo pedido</button>
        <button class="btn btn-sm" onclick="eliminarCliente(${c.id})" style="border-color:var(--terracotta);color:var(--terracotta)">Eliminar</button>
      </div>
    </div>
  `).join('');
}

async function eliminarCliente(id) {
  if (!confirm('¿Eliminar cliente?')) return;
  const prev = [...clientes];
  clientes = clientes.filter(c => c.id !== id);
  renderClientes();
  try {
    await api('deleteCliente', { id });
    toast('Cliente eliminado');
  } catch (e) {
    clientes = prev;
    renderClientes();
    toast('Error al eliminar', 'error');
  }
}

function nuevoPedidoCliente(clienteId) {
  showTab('pedidos', document.querySelectorAll('.tab-btn')[0]);
  openModal('modal-pedido');
  setTimeout(() => { document.getElementById('ped-cliente').value = clienteId; }, 50);
}

// ================================================================
//  RENDER — PRODUCTOS
// ================================================================
function renderProductos() {
  const grid = document.getElementById('productos-grid');
  if (productos.length === 0) {
    grid.innerHTML = '<div class="empty-state" style="grid-column:1/-1"><span class="emoji">🧀</span>Agrega tu primer producto</div>';
    return;
  }
  grid.innerHTML = productos.map(p => {
    const tagClass = { pasta: 'tag-pasta', embutido: 'tag-embutido', lacteo: 'tag-lacteo', otro: 'tag-otro' }[p.cat] || 'tag-otro';
    return `
      <div class="card" style="${!p.disponible ? 'opacity:0.5' : ''}">
        <div class="card-label">Catálogo Alimentari</div>
        <div class="card-name">${p.nombre}</div>
        <div style="margin:8px 0"><span class="tag ${tagClass}">${p.cat}</span></div>
        <div class="card-detail" style="font-size:1rem;font-weight:500;color:var(--terracotta)">${formatMXN(p.precio)} / ${p.unidad}</div>
        <div class="card-detail" style="margin-top:4px">${p.disponible ? '✓ Disponible' : '✗ No disponible'}</div>
        <div class="card-actions">
          <button class="btn btn-sm" onclick="toggleDisponible(${p.id})">${p.disponible ? 'Deshabilitar' : 'Habilitar'}</button>
          <button class="btn btn-sm" onclick="eliminarProducto(${p.id})" style="border-color:var(--terracotta);color:var(--terracotta)">Eliminar</button>
        </div>
      </div>
    `;
  }).join('');
}

async function toggleDisponible(id) {
  const p = productos.find(x => x.id === id);
  if (!p) return;
  const nuevoVal = p.disponible ? 0 : 1;
  p.disponible = nuevoVal;
  renderProductos();
  try {
    await api('updateProducto', { id, cambios: { disponible: nuevoVal } });
    toast('Producto actualizado');
  } catch (e) {
    p.disponible = nuevoVal ? 0 : 1;
    renderProductos();
    toast('Error al actualizar', 'error');
  }
}

async function eliminarProducto(id) {
  if (!confirm('¿Eliminar producto?')) return;
  const prev = [...productos];
  productos = productos.filter(p => p.id !== id);
  renderProductos();
  try {
    await api('deleteProducto', { id });
    toast('Producto eliminado');
  } catch (e) {
    productos = prev;
    renderProductos();
    toast('Error al eliminar', 'error');
  }
}

// ================================================================
//  FORM — GUARDAR CLIENTE
// ================================================================
async function guardarCliente() {
  const nombre = document.getElementById('cli-nombre').value.trim();
  if (!nombre) { toast('Ingresa el nombre del restaurante', 'error'); return; }

  const btn = document.getElementById('btn-guardar-cliente');
  btn.disabled = true;
  btn.textContent = 'Guardando...';

  const nuevo = {
    id:       Date.now(),
    nombre,
    contacto: document.getElementById('cli-contacto').value,
    tel:      document.getElementById('cli-tel').value,
    email:    document.getElementById('cli-email').value,
    rfc:      document.getElementById('cli-rfc').value,
    dir:      document.getElementById('cli-dir').value,
    dias:     document.getElementById('cli-dias').value,
  };

  try {
    await api('addCliente', { data: nuevo });
    clientes.push(nuevo);
    closeModal('modal-cliente');
    renderClientes();
    document.querySelectorAll('#modal-cliente input').forEach(i => i.value = '');
    toast('Cliente guardado ✓');
  } catch (e) {
    toast('Error al guardar: ' + e.message, 'error');
  } finally {
    btn.disabled = false;
    btn.textContent = 'Guardar cliente';
  }
}

// ================================================================
//  FORM — GUARDAR PRODUCTO
// ================================================================
async function guardarProducto() {
  const nombre = document.getElementById('pro-nombre').value.trim();
  const precio = parseFloat(document.getElementById('pro-precio').value);
  if (!nombre || !precio) { toast('Completa nombre y precio', 'error'); return; }

  const btn = document.getElementById('btn-guardar-producto');
  btn.disabled = true;
  btn.textContent = 'Guardando...';

  const nuevo = {
    id:         Date.now(),
    nombre,
    cat:        document.getElementById('pro-cat').value,
    unidad:     document.getElementById('pro-unidad').value,
    precio,
    disponible: parseInt(document.getElementById('pro-disponible').value),
  };

  try {
    await api('addProducto', { data: nuevo });
    productos.push(nuevo);
    closeModal('modal-producto');
    renderProductos();
    document.getElementById('pro-nombre').value = '';
    document.getElementById('pro-precio').value = '';
    toast('Producto guardado ✓');
  } catch (e) {
    toast('Error al guardar: ' + e.message, 'error');
  } finally {
    btn.disabled = false;
    btn.textContent = 'Guardar producto';
  }
}

// ================================================================
//  FORM — PEDIDO (items)
// ================================================================
let itemsPedido = [];

function renderClientesSelect() {
  const sel = document.getElementById('ped-cliente');
  sel.innerHTML = '<option value="">Selecciona cliente...</option>' +
    clientes.map(c => `<option value="${c.id}">${c.nombre}</option>`).join('');
}

function renderProductosPedidoList(items) {
  itemsPedido = items;
  const container = document.getElementById('productos-pedido-list');
  if (itemsPedido.length === 0) {
    container.innerHTML = '<div style="font-size:0.75rem;color:var(--muted);margin-bottom:8px">Sin productos aún</div>';
    return;
  }
  const disponibles = productos.filter(p => p.disponible);
  container.innerHTML = itemsPedido.map((item, idx) => `
    <div class="producto-row">
      <select onchange="itemsPedido[${idx}].productoId=parseInt(this.value)"
        style="font-family:'DM Mono',monospace;font-size:0.75rem;border:1px solid var(--light-border);padding:6px;background:var(--cream)">
        <option value="">Producto...</option>
        ${disponibles.map(p => `<option value="${p.id}" ${p.id===item.productoId?'selected':''}>${p.nombre} – ${formatMXN(p.precio)}/${p.unidad}</option>`).join('')}
      </select>
      <input type="number" min="1" value="${item.qty}"
        style="width:60px;font-family:'DM Mono',monospace;font-size:0.75rem;border:1px solid var(--light-border);padding:6px;background:var(--cream)"
        onchange="itemsPedido[${idx}].qty=parseInt(this.value)||1">
      <button class="remove-btn" onclick="quitarItem(${idx})">✕</button>
    </div>
  `).join('');
}

function agregarProductoPedido() {
  itemsPedido.push({ productoId: productos.find(p=>p.disponible)?.id || 0, qty: 1 });
  renderProductosPedidoList(itemsPedido);
}

function quitarItem(idx) {
  itemsPedido.splice(idx, 1);
  renderProductosPedidoList(itemsPedido);
}

// ================================================================
//  FORM — GUARDAR PEDIDO
// ================================================================
async function guardarPedido() {
  const clienteId = parseInt(document.getElementById('ped-cliente').value);
  if (!clienteId)           { toast('Selecciona un cliente', 'error'); return; }
  if (itemsPedido.length === 0) { toast('Agrega al menos un producto', 'error'); return; }

  const btn = document.getElementById('btn-guardar-pedido');
  btn.disabled = true;
  btn.textContent = 'Guardando...';

  const nuevo = {
    id:        Date.now(),
    clienteId,
    items:     [...itemsPedido],
    fecha:     document.getElementById('ped-fecha').value,
    estado:    'Recibido',
    pago:      document.getElementById('ped-pago').value,
    factura:   'Sin factura',
    notas:     document.getElementById('ped-notas').value,
  };

  try {
    await api('addPedido', { data: nuevo });
    pedidos.push(nuevo);
    closeModal('modal-pedido');
    renderAll();
    toast('Pedido guardado ✓');
  } catch (e) {
    toast('Error al guardar: ' + e.message, 'error');
  } finally {
    btn.disabled = false;
    btn.textContent = 'Guardar pedido';
  }
}

// ================================================================
//  RENDER ALL
// ================================================================
function renderAll() {
  renderStats();
  renderPedidos();
  renderClientes();
  renderProductos();
}

// ================================================================
//  INIT — carga datos al abrir
// ================================================================
(async () => {
  const overlay = document.getElementById('loading-overlay');
  try {
    await cargarTodo();
    renderAll();
  } catch (e) {
    document.querySelector('.loading-text').textContent = 'Error al conectar con la base de datos';
    document.querySelector('.loading-text').style.color = '#C4613A';
    console.error(e);
    return; // no ocultar overlay si hay error de conexión
  }
  overlay.classList.add('hidden');
  setTimeout(() => overlay.style.display = 'none', 400);
})();
</script>
